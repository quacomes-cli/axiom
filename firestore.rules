rules_version = '2';

// Axiom Firestore güvenlik kuralları.
// NOT: Bu dosyayı Firebase'e deploy etmek kullanıcı aksiyonudur
// (`firebase deploy --only firestore:rules`). Ayrıca telefon eşleştirmesi
// için Firebase konsolunda **Anonymous Authentication** etkinleştirilmelidir.
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcıya ait sohbet/ayar/profil verisi — yalnızca kendi UID'si.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // WebRTC signaling — yalnızca SDP/ICE taşır (geçici). Herhangi bir kimlik
    // doğrulanmış (anonim dahil) istemci okuyup yazabilir. Gerçek sohbet verisi
    // BURAYA YAZILMAZ; P2P data channel'dan akar. sessionId tahmin edilemez ve
    // el sıkışma ayrıca secret ile korunur.
    match /signaling/{sessionId} {
      allow read, write: if request.auth != null;
      match /{sub=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
